# Copier en `.env` et renseigner. Le `.env` est local au dossier (gitignoré).
# ANTHROPIC_API_KEY : obligatoire pour l'OCR (Claude Vision) et la passe LLM nom→ticker.
# QUIVER_API_KEY    : optionnel — le cache Quiver est déjà embarqué (data_v1/tables/_quiver_house_cache.csv) ;
#                     la clé ne sert qu'à rafraîchir ce cache.
ANTHROPIC_API_KEY=
QUIVER_API_KEY=
