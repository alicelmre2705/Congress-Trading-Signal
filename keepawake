#!/usr/bin/env bash
# keepawake — empêche le Mac de se mettre en veille (sleep).
#
# Mode session (couvre Claude Code, Jupyter, pipelines — tout en même temps) :
#   ./keepawake on        # garde le Mac éveillé jusqu'à 'off'
#   ./keepawake off       # rétablit la veille normale
#   ./keepawake status
#
# Mode commande (verrou relâché à la fin de la commande) :
#   ./keepawake python "0 HOUSE/house_multiyear.py" --years 2020,2021
#   ./keepawake jupyter lab
#   ./keepawake claude    # lance Claude Code en restant éveillé
#
# Alternative — protéger un job DÉJÀ lancé sans le relancer :
#   caffeinate -i -m -w <PID>   # se termine quand le PID surveillé finit
#
# Note : caffeinate n'empêche PAS la veille quand on rabat l'écran d'un MacBook
# (clamshell). Pour travailler écran fermé : écran ouvert + secteur, écran externe,
# ou un outil tiers (Amphetamine).
set -euo pipefail

PIDFILE="${TMPDIR:-/tmp}/keepawake.pid"

is_running() { [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; }

case "${1:-}" in
  on)
    if is_running; then
      echo "☕ keepawake déjà actif (PID $(cat "$PIDFILE"))." >&2; exit 0
    fi
    nohup caffeinate -i -m >/dev/null 2>&1 &
    echo $! > "$PIDFILE"; disown 2>/dev/null || true
    echo "☕ keepawake ACTIVÉ (PID $(cat "$PIDFILE")). Le Mac ne s'endormira plus." >&2
    echo "   → './keepawake off' pour rétablir la veille normale." >&2
    ;;
  off)
    if is_running; then
      kill "$(cat "$PIDFILE")" 2>/dev/null || true; rm -f "$PIDFILE"
      echo "💤 keepawake désactivé. La veille normale reprend." >&2
    else
      rm -f "$PIDFILE"; echo "keepawake n'était pas actif." >&2
    fi
    ;;
  status)
    if is_running; then echo "☕ keepawake ACTIF (PID $(cat "$PIDFILE"))." >&2
    else echo "💤 keepawake inactif (veille normale)." >&2; fi
    ;;
  "")
    echo "Usage:" >&2
    echo "  keepawake on|off|status      # mode session (couvre Claude Code)" >&2
    echo "  keepawake <commande> [args]  # garde éveillé le temps d'une commande" >&2
    exit 1
    ;;
  *)
    echo "☕ keepawake : Mac éveillé jusqu'à la fin de : $*" >&2
    exec caffeinate -i -m -- "$@"
    ;;
esac
